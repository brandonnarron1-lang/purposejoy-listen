{
  "name": "purposejoy-listen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name=purposejoy-listen --branch=main",
    "shorts:identify": "node scripts/shorts/identify-hooks.js",
    "shorts:compose": "node scripts/shorts/compose-short.js",
    "shorts:upload": "node scripts/shorts/upload-short.js",
    "shorts:oauth": "node scripts/shorts/oauth-init.js",
    "lyrics:normalize": "node INGEST/scripts/normalize-lyrics.js",
    "lyrics:push": "npx wrangler d1 execute purposejoy_db --file=INGEST/scripts/update-lyrics.sql"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@tailwindcss/vite": "^4.2.4",
    "colorthief": "^3.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.86.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@img/sharp-darwin-arm64": "^0.35.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "sharp": "^0.35.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
